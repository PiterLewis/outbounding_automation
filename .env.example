# y habilita Google Forms API + Google Drive API.
# El refresh token se obtiene una sola vez corriendo:
#   node --env-file=./.env apps/backend/src/scripts/getGoogleRefreshToken.js
GOOGLE_CLIENT_ID=sample
GOOGLE_CLIENT_SECRET=sample
GOOGLE_REFRESH_TOKEN=sample